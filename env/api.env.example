# Copy this file to env/api.env on the EC2 host and fill in real values there.
# Do not commit env/api.env.

NODE_ENV=production
PORT=5000

# AWS RDS MySQL connection
DB_HOST=your-rds-endpoint.amazonaws.com
DB_PORT=3306
DB_NAME=employee_management
DB_USER=ems_api_user
DB_PASSWORD=replace-with-secure-password
DB_CONNECTION_LIMIT=10
DB_QUEUE_LIMIT=0

# JWT configuration
JWT_SECRET=replace-with-a-long-random-secret
JWT_EXPIRE=7d
REFRESH_TOKEN_EXPIRE=30d

# Public frontend origin used by API CORS
FRONTEND_URL=https://your-domain.example

# Optional email configuration, required only if password reset email is enabled
EMAIL_HOST=smtp.example.com
EMAIL_PORT=465
EMAIL_SECURE=true
EMAIL_USER=replace-with-email-user
EMAIL_PASS=replace-with-email-password
EMAIL_FROM=no-reply@your-domain.example
