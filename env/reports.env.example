# Copy this file to env/reports.env on the EC2 host and fill in real values there.
# Do not commit env/reports.env.

SERVICE_PORT=8001

# AWS RDS MySQL connection
DB_HOST=your-rds-endpoint.amazonaws.com
DB_PORT=3306
DB_NAME=employee_management
DB_USER=ems_reports_user
DB_PASSWORD=replace-with-secure-password

# Must match the API JWT secret because reports validates API-issued tokens.
JWT_SECRET=replace-with-the-same-long-random-secret-used-by-api
JWT_EXPIRE=7d
